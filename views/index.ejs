<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CryptoTracker — CN</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        :root {
            --gold: #f0b90b;
            --gold-dim: rgba(240,185,11,0.12);
            --gold-glow: rgba(240,185,11,0.25);
            --green: #0ecb81;
            --red: #f6465d;
            --bg: #000000;
            --bg2: #080808;
            --bg3: #0d0d0d;
            --border: rgba(255,255,255,0.08);
            --text-muted: #555;
            --text-dim: #999;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: var(--bg);
            color: #fff;
            font-family: 'JetBrains Mono', monospace;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Fundo com Grelha Animada */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image:
                linear-gradient(rgba(240,185,11,0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(240,185,11,0.03) 1px, transparent 1px);
            background-size: 50px 50px;
            pointer-events: none;
            z-index: 0;
        }

        .wrapper {
            position: relative;
            z-index: 1;
            max-width: 1200px;
            margin: 0 auto;
            padding: 60px 24px;
        }

        header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 60px;
            padding-bottom: 30px;
            border-bottom: 1px solid var(--border);
        }

        .logo { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 2.2rem; letter-spacing: -0.04em; line-height: 1; }
        .logo span { color: var(--gold); text-shadow: 0 0 20px var(--gold-glow); }

        .live-badge { display: inline-flex; align-items: center; gap: 8px; font-size: 0.7rem; letter-spacing: 0.2em; color: var(--green); text-transform: uppercase; border: 1px solid rgba(14,203,129,0.2); padding: 6px 14px; border-radius: 50px; background: rgba(14,203,129,0.05); }
        .live-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--green); box-shadow: 0 0 10px var(--green); animation: pulse 2s infinite; }

        @keyframes pulse { 0% { opacity: 1; transform: scale(1); } 50% { opacity: 0.3; transform: scale(0.8); } 100% { opacity: 1; transform: scale(1); } }

        /* Tabela Estilizada */
        .crypto-table { width: 100%; border-collapse: separate; border-spacing: 0 12px; margin-bottom: 60px; }
        .crypto-table thead th { font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-dim); padding: 10px 20px; font-weight: 500; }
        
        .coin-row { background: var(--bg2); border: 1px solid var(--border); transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); cursor: pointer; }
        .coin-row:hover { background: var(--bg3); border-color: var(--gold-dim); transform: scale(1.01); box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        .coin-row td { padding: 25px 20px; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
        .coin-row td:first-child { border-left: 1px solid var(--border); border-radius: 12px 0 0 12px; }
        .coin-row td:last-child { border-right: 1px solid var(--border); border-radius: 0 12px 12px 0; }

        .coin-name { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1.1rem; color: #fff; }
        .price-val { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1.3rem; color: var(--gold); }

        /* Dashboard de Relatórios */
        .reports-dashboard { margin-top: 80px; padding: 40px; background: linear-gradient(180deg, var(--bg2) 0%, var(--bg) 100%); border: 1px solid var(--border); border-radius: 20px; box-shadow: 0 20px 50px rgba(0,0,0,0.4); }
        .dashboard-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 35px; }
        .dashboard-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.2rem; color: #fff; text-transform: uppercase; letter-spacing: 0.1em; }
        
        .report-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px; }
        .report-item { background: rgba(255,255,255,0.02); border: 1px solid var(--border); padding: 20px; border-radius: 12px; display: flex; align-items: center; justify-content: space-between; transition: 0.3s; }
        .report-item:hover { background: rgba(240,185,11,0.03); border-color: var(--gold-dim); }
        
        .report-icon { width: 40px; height: 40px; background: var(--gold-dim); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: var(--gold); font-size: 1.2rem; margin-right: 15px; }
        .report-info { flex: 1; min-width: 0; }
        .report-name { display: block; font-size: 0.8rem; font-weight: 600; color: #eee; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-bottom: 4px; }
        .report-meta { font-size: 0.6rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.1em; }

        .btn-action { background: var(--gold); color: #000; border: none; padding: 10px 20px; border-radius: 8px; font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.75rem; text-transform: uppercase; transition: 0.3s; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; }
        .btn-action:hover { background: #fff; transform: translateY(-2px); box-shadow: 0 5px 15px var(--gold-glow); }
        .btn-action:disabled { background: var(--text-muted); cursor: not-allowed; }

        .btn-download { background: rgba(255,255,255,0.05); color: #fff; border: 1px solid var(--border); font-size: 0.65rem; padding: 8px 15px; border-radius: 6px; text-decoration: none; transition: 0.2s; }
        .btn-download:hover { background: var(--gold-dim); color: var(--gold); border-color: var(--gold); }

        footer { margin-top: 80px; padding: 40px 0; border-top: 1px solid var(--border); text-align: center; }
        .footer-text { font-size: 0.65rem; color: var(--text-muted); letter-spacing: 0.2em; }
    </style>
</head>
<body>

<div class="wrapper">
    <header>
        <div class="logo">CRYPTO<span>TRACKER</span></div>
        <div class="header-right" style="display:flex; align-items:center; gap:30px;">
            <div id="clock" style="font-size:0.8rem; color:var(--text-dim); letter-spacing:0.1em;">00:00:00</div>
            <div class="live-badge"><span class="live-dot"></span> System Live</div>
        </div>
    </header>

    <table class="crypto-table">
        <thead>
            <tr>
                <th>Asset</th>
                <th>Price Index</th>
                <th style="text-align:center">Performance</th>
                <th style="text-align:right">Actions</th>
            </tr>
        </thead>
        <tbody>
            <% if (coinData) { %>
                <% Object.keys(coinData).forEach((coin, i) => {
                    const cur = coinData[coin][coinData[coin].length - 1]?.price || 0;
                %>
                <tr class="coin-row" id="row-<%= coin %>" onclick="toggleDetail('<%= coin %>')">
                    <td>
                        <div class="coin-name"><%= coin.toUpperCase() %></div>
                        <div style="font-size:0.6rem; color:var(--text-muted);">COINGECKO / EUR</div>
                    </td>
                    <td><span class="price-val" id="price-<%= coin %>" data-raw="<%= cur %>"><%= cur.toLocaleString('pt-PT', {minimumFractionDigits:2}) %>€</span></td>
                    <td style="text-align:center"><span id="trend-<%= coin %>" style="font-size:0.8rem; color:var(--text-dim);">—</span></td>
                    <td style="text-align:right"><button class="btn-download">VIEW CHART</button></td>
                </tr>
                <tr id="detail-row-<%= coin %>" style="display:none;"><td colspan="4">
                    <div style="padding:40px; background:var(--bg3); border-radius:12px; margin: 10px 0;">
                        <div style="height:250px;"><canvas id="chart-<%= coin %>"></canvas></div>
                    </div>
                </td></tr>
                <% }); %>
            <% } %>
        </tbody>
    </table>

    <div class="reports-dashboard">
        <div class="dashboard-header">
            <div class="dashboard-title">Vault / Generated Reports</div>
            <button class="btn-action" onclick="requestReport(this)">
                <span>Generate New Audit</span>
            </button>
        </div>
        
        <div class="report-grid" id="listaRelatorios">
            <% if (typeof reports !== 'undefined' && reports.length > 0) { %>
                <% reports.forEach(function(report) { %>
                    <div class="report-item">
                        <div class="report-icon">PDF</div>
                        <div class="report-info">
                            <span class="report-name"><%= report %></span>
                            <span class="report-meta">Secured / Blob Storage</span>
                        </div>
                        <a href="/api/download/<%= report %>" class="btn-download" target="_blank">Download</a>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="empty-state">No audit logs found in the vault.</div>
            <% } %>
        </div>
    </div>

    <footer>
        <div class="footer-text">IPCB CLOUD COMPUTING / 2026 EDITION</div>
        <div style="margin-top:10px; font-size:0.55rem; color:var(--text-muted);">JOÃO OLIVEIRA • TIAGO PINHEIRO • TIAGO COVAS</div>
    </footer>
</div>

<script>
    const socket = io();
    const charts = {};
    const coinHistories = <%- JSON.stringify(coinData) %>;

    function updateClock() { document.getElementById('clock').textContent = new Date().toLocaleTimeString('pt-PT'); }
    setInterval(updateClock, 1000); updateClock();

    function toggleDetail(coin) {
        const row = document.getElementById(`detail-row-${coin}`);
        const isVisible = row.style.display !== 'none';
        document.querySelectorAll('[id^="detail-row-"]').forEach(r => r.style.display = 'none');
        if (!isVisible) {
            row.style.display = 'table-row';
            if (!charts[coin]) initChart(coin);
        }
    }

    function initChart(coin) {
        const ctx = document.getElementById(`chart-${coin}`).getContext('2d');
        const data = coinHistories[coin];
        charts[coin] = new Chart(ctx, {
            type: 'line',
            data: {
                labels: data.map(d => new Date(d.timestamp).toLocaleTimeString()),
                datasets: [{ 
                    data: data.map(d => d.price), 
                    borderColor: '#f0b90b', 
                    borderWidth: 2,
                    pointRadius: 0,
                    tension: 0.4,
                    fill: true,
                    backgroundColor: 'rgba(240,185,11,0.05)'
                }]
            },
            options: { 
                responsive: true, 
                maintainAspectRatio: false, 
                plugins: { legend: { display: false } },
                scales: { 
                    x: { display: false }, 
                    y: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#555', font: { size: 10 } } } 
                }
            }
        });
    }

    async function requestReport(btn) {
        const originalText = btn.innerHTML;
        btn.disabled = true; btn.innerHTML = "<span>Processing Audit...</span>";
        try {
            const res = await fetch('/api/generate-report', { method: 'POST' });
            const result = await res.json();
            if (result.success) {
                const grid = document.getElementById('listaRelatorios');
                const empty = grid.querySelector('.empty-state');
                if (empty) empty.remove();

                const div = document.createElement('div');
                div.className = 'report-item';
                div.innerHTML = `
                    <div class="report-icon">PDF</div>
                    <div class="report-info">
                        <span class="report-name">${result.filename}</span>
                        <span class="report-meta">Secured / Blob Storage</span>
                    </div>
                    <a href="/api/download/${result.filename}" class="btn-download" target="_blank">Download</a>
                `;
                grid.prepend(div);
            }
        } catch (err) { alert("Vault communication failed."); }
        finally { btn.disabled = false; btn.innerHTML = originalText; }
    }

    socket.on('priceUpdate', (newPrices) => {
        Object.keys(newPrices).forEach(coin => {
            const el = document.getElementById(`price-${coin}`);
            if (el) {
                const oldPrice = parseFloat(el.getAttribute('data-raw') || 0);
                const price = newPrices[coin];
                el.textContent = price.toLocaleString('pt-PT', {minimumFractionDigits:2}) + '€';
                el.setAttribute('data-raw', price);
                
                const trend = document.getElementById(`trend-${coin}`);
                if (price > oldPrice) trend.textContent = '▲', trend.style.color = 'var(--green)';
                else if (price < oldPrice) trend.textContent = '▼', trend.style.color = 'var(--red)';
            }
        });
    });
</script>
</body>
</html>