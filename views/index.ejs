<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CryptoTracker — CN</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        :root { --gold: #f0b90b; --gold-dim: rgba(240,185,11,0.12); --gold-glow: rgba(240,185,11,0.25); --green: #0ecb81; --red: #f6465d; --bg: #000000; --bg2: #080808; --bg3: #0d0d0d; --border: rgba(255,255,255,0.08); --text-muted: #555; --text-dim: #999; }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { background: var(--bg); color: #fff; font-family: 'JetBrains Mono', monospace; min-height: 100vh; overflow-x: hidden; }
        body::before { content: ''; position: fixed; inset: 0; background-image: linear-gradient(rgba(240,185,11,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(240,185,11,0.03) 1px, transparent 1px); background-size: 50px 50px; pointer-events: none; z-index: 0; }
        .wrapper { position: relative; z-index: 1; max-width: 1200px; margin: 0 auto; padding: 60px 24px; }
        header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 60px; padding-bottom: 30px; border-bottom: 1px solid var(--border); }
        .logo { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 2.2rem; letter-spacing: -0.04em; line-height: 1; }
        .logo span { color: var(--gold); text-shadow: 0 0 20px var(--gold-glow); }
        .live-badge { display: inline-flex; align-items: center; gap: 8px; font-size: 0.7rem; color: var(--green); text-transform: uppercase; border: 1px solid rgba(14,203,129,0.2); padding: 6px 14px; border-radius: 50px; background: rgba(14,203,129,0.05); }
        .live-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--green); animation: pulse 2s infinite; }
        @keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.3; } 100% { opacity: 1; } }
        .crypto-table { width: 100%; border-collapse: separate; border-spacing: 0 12px; }
        .coin-row { background: var(--bg2); cursor: pointer; transition: 0.3s; }
        .coin-row:hover { background: var(--bg3); border-color: var(--gold-dim); transform: scale(1.01); }
        .price-val { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1.3rem; color: var(--gold); }
        .detail-panel { background: var(--bg3); border-radius: 12px; margin-top: -5px; border: 1px solid var(--border); overflow: hidden; }
        .detail-inner { display: grid; grid-template-columns: 300px 1fr; }
        .calc-side { padding: 30px; border-right: 1px solid var(--border); background: rgba(0,0,0,0.2); }
        .calc-input { background: var(--bg); border: 1px solid var(--border); color: #fff; padding: 12px; border-radius: 6px; width: 100%; margin-bottom: 15px; }
        .profit-amount { font-family: 'Syne', sans-serif; font-size: 1.8rem; font-weight: 700; }
        .pos { color: var(--green); } .neg { color: var(--red); }
        .reports-dashboard { margin-top: 80px; padding: 40px; background: linear-gradient(180deg, var(--bg2) 0%, var(--bg) 100%); border: 1px solid var(--border); border-radius: 20px; }
        .report-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px; margin-top: 25px; }
        .report-item { background: rgba(255,255,255,0.02); border: 1px solid var(--border); padding: 20px; border-radius: 12px; display: flex; align-items: center; justify-content: space-between; }
        .btn-action { background: var(--gold); color: #000; border: none; padding: 12px 24px; border-radius: 8px; font-family: 'Syne', sans-serif; font-weight: 700; text-transform: uppercase; cursor: pointer; }
        .btn-download { background: rgba(255,255,255,0.05); color: #fff; border: 1px solid var(--border); font-size: 0.65rem; padding: 8px 15px; border-radius: 6px; text-decoration: none; }
    </style>
</head>
<body>

<div class="wrapper">
    <header>
        <div class="logo">CRYPTO<span>TRACKER</span></div>
        <div style="display:flex; align-items:center; gap:30px;">
            <div id="clock" style="font-size:0.8rem; color:var(--text-dim);">00:00:00</div>
            <div class="live-badge"><span class="live-dot"></span> System Live</div>
        </div>
    </header>

    <table class="crypto-table">
        <thead><tr><th>Moeda</th><th>Preço Index</th><th style="text-align:center">Performance</th><th style="text-align:right">Ações</th></tr></thead>
        <tbody>
            <% if (typeof coinData !== 'undefined') { %>
                <% Object.keys(coinData).forEach((coin) => {
                    const cur = coinData[coin][coinData[coin].length - 1]?.price || 0;
                %>
                <tr class="coin-row" onclick="toggleDetail('<%= coin %>')">
                    <td><div style="font-weight:700; font-family:'Syne';"><%= coin.toUpperCase() %></div><div style="font-size:0.6rem; color:var(--text-muted);">COINGECKO / EUR</div></td>
                    <td><span class="price-val" id="price-<%= coin %>" data-raw="<%= cur %>"><%= cur.toLocaleString('pt-PT', {minimumFractionDigits:2}) %>€</span></td>
                    <td style="text-align:center"><span id="trend-<%= coin %>">—</span></td>
                    <td style="text-align:right"><button class="btn-download">+ VER</button></td>
                </tr>
                <tr id="detail-row-<%= coin %>" style="display:none;"><td colspan="4">
                    <div class="detail-panel">
                        <div class="detail-inner">
                            <div class="calc-side">
                                <div style="font-size:0.6rem; color:var(--gold); margin-bottom:15px;">CALCULADORA DE LUCRO</div>
                                <input type="number" class="calc-input qty-in" data-coin="<%= coin %>" placeholder="Quantidade">
                                <input type="number" class="calc-input buy-in" data-coin="<%= coin %>" placeholder="Preço Compra (€)">
                                <div class="profit-amount" id="profit-<%= coin %>">0.00€</div>
                            </div>
                            <div style="padding:30px;"><div style="height:250px;"><canvas id="chart-<%= coin %>"></canvas></div></div>
                        </div>
                    </div>
                </td></tr>
                <% }); %>
            <% } %>
        </tbody>
    </table>

    <div class="reports-dashboard">
        <div style="display:flex; justify-content:space-between; align-items:center;">
            <div style="font-family:'Syne'; font-weight:800;">VAULT / RELATÓRIOS</div>
            <button class="btn-action" onclick="requestReport(this)">Gerar Auditoria</button>
        </div>
        <div class="report-grid" id="listaRelatorios">
            <% if (typeof reports !== 'undefined' && reports.length > 0) { %>
                <% reports.forEach(function(report) { %>
                    <div class="report-item">
                        <div><div style="font-size:0.8rem; font-weight:600;"><%= report %></div><div style="font-size:0.6rem; color:var(--text-muted);">Azure Storage / PDF</div></div>
                        <a href="/api/download/<%= report %>" class="btn-download" target="_blank">Download</a>
                    </div>
                <% }); %>
            <% } else { %><div style="color:var(--text-dim); padding:20px;">Nenhum relatório encontrado.</div><% } %>
        </div>
    </div>
</div>

<script>
    const socket = io();
    const charts = {};
    const coinHistories = <%- JSON.stringify(coinData) %>;

    function updateClock() { document.getElementById('clock').textContent = new Date().toLocaleTimeString('pt-PT'); }
    setInterval(updateClock, 1000); updateClock();

    function toggleDetail(coin) {
        const row = document.getElementById(`detail-row-${coin}`);
        const isVisible = row.style.display !== 'none';
        document.querySelectorAll('[id^="detail-row-"]').forEach(r => r.style.display = 'none');
        if (!isVisible) {
            row.style.display = 'table-row';
            if (!charts[coin]) initChart(coin);
        }
    }

    function initChart(coin) {
        const ctx = document.getElementById(`chart-${coin}`).getContext('2d');
        const data = coinHistories[coin] || [];
        charts[coin] = new Chart(ctx, {
            type: 'line',
            data: {
                labels: data.map(d => new Date(d.timestamp).toLocaleTimeString()),
                datasets: [{ 
                    data: data.map(d => d.price), borderColor: '#f0b90b', borderWidth: 2,
                    pointRadius: 4, pointHoverRadius: 7, pointBackgroundColor: '#f0b90b', tension: 0.4, fill: true, backgroundColor: 'rgba(240,185,11,0.05)'
                }]
            },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
        });
    }

    async function requestReport(btn) {
        btn.disabled = true; btn.textContent = "A Processar...";
        try {
            const res = await fetch('/api/generate-report', { method: 'POST' });
            const result = await res.json();
            if (result.success) location.reload();
            else alert("Erro no Servidor: " + result.error);
        } catch (err) { alert("Erro na comunicação."); }
        finally { btn.disabled = false; btn.textContent = "Gerar Auditoria"; }
    }

    document.addEventListener('input', (e) => {
        if (e.target.classList.contains('qty-in') || e.target.classList.contains('buy-in')) {
            const coin = e.target.dataset.coin;
            const qty = parseFloat(document.querySelector(`.qty-in[data-coin="${coin}"]`).value) || 0;
            const buy = parseFloat(document.querySelector(`.buy-in[data-coin="${coin}"]`).value) || 0;
            const current = parseFloat(document.getElementById(`price-${coin}`).getAttribute('data-raw'));
            const profit = (current - buy) * qty;
            const display = document.getElementById(`profit-${coin}`);
            display.textContent = profit.toLocaleString('pt-PT', {minimumFractionDigits:2}) + '€';
            display.className = 'profit-amount ' + (profit >= 0 ? 'pos' : 'neg');
        }
    });

    socket.on('priceUpdate', (newPrices) => {
        Object.keys(newPrices).forEach(coin => {
            const el = document.getElementById(`price-${coin}`);
            if (el) {
                const old = parseFloat(el.getAttribute('data-raw') || 0);
                const price = newPrices[coin];
                el.textContent = price.toLocaleString('pt-PT', {minimumFractionDigits:2}) + '€';
                el.setAttribute('data-raw', price);
                const trend = document.getElementById(`trend-${coin}`);
                if (price > old) { trend.textContent = '▲'; trend.style.color = 'var(--green)'; }
                else if (price < old) { trend.textContent = '▼'; trend.style.color = 'var(--red)'; }
            }
        });
    });
</script>
</body>
</html>