<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CryptoTracker — CN</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        :root { --gold: #f0b90b; --gold-dim: rgba(240,185,11,0.12); --gold-glow: rgba(240,185,11,0.25); --green: #0ecb81; --red: #f6465d; --bg: #000000; --bg2: #080808; --bg3: #0d0d0d; --border: rgba(255,255,255,0.06); --text-muted: #4a4a4a; --text-dim: #888; }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { background: var(--bg); color: #fff; font-family: 'JetBrains Mono', monospace; min-height: 100vh; overflow-x: hidden; }
        body::before { content: ''; position: fixed; inset: 0; background-image: linear-gradient(rgba(240,185,11,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(240,185,11,0.03) 1px, transparent 1px); background-size: 40px 40px; pointer-events: none; z-index: 0; }
        .wrapper { position: relative; z-index: 1; max-width: 1100px; margin: 0 auto; padding: 48px 24px; }
        header { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 48px; padding-bottom: 24px; border-bottom: 1px solid var(--border); }
        .logo { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 2rem; letter-spacing: -0.03em; line-height: 1; }
        .logo span { color: var(--gold); }
        .header-meta { text-align: right; }
        .live-badge { display: inline-flex; align-items: center; gap: 6px; font-size: 0.65rem; letter-spacing: 0.15em; color: var(--green); text-transform: uppercase; margin-bottom: 4px; }
        .live-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--green); animation: pulse 1.5s ease-in-out infinite; }
        @keyframes pulse { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.4; transform: scale(0.7); } }
        .clock { font-size: 0.7rem; color: var(--text-dim); letter-spacing: 0.08em; }
        .crypto-table { width: 100%; border-collapse: collapse; margin-bottom: 60px; }
        .crypto-table thead th { font-size: 0.6rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-muted); padding: 0 16px 16px; border-bottom: 1px solid var(--border); font-weight: 400; }
        .crypto-table thead th:last-child { text-align: right; }
        .coin-row { cursor: pointer; transition: background 0.2s; border-bottom: 1px solid var(--border); animation: rowIn 0.4s ease both; }
        @keyframes rowIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
        .coin-row:hover { background: rgba(255,255,255,0.02); }
        .coin-row.active { background: var(--gold-dim); border-bottom-color: transparent; }
        .coin-row td { padding: 20px 16px; vertical-align: middle; }
        .coin-name { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1rem; letter-spacing: 0.05em; text-transform: uppercase; }
        .price-val { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1.15rem; letter-spacing: -0.02em; transition: color 0.3s; }
        .reports-dashboard { margin-top: 40px; background: var(--bg2); border: 1px solid var(--border); border-radius: 8px; padding: 28px; }
        .dashboard-title { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1rem; letter-spacing: 0.1em; color: var(--gold); text-transform: uppercase; margin-bottom: 24px; border-bottom: 1px solid var(--border); padding-bottom: 12px; }
        .report-list { list-style: none; display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 16px; }
        .report-item { background: var(--bg3); border: 1px solid var(--border); padding: 16px; border-radius: 4px; display: flex; align-items: center; justify-content: space-between; transition: transform 0.2s; }
        .report-item:hover { transform: translateY(-2px); border-color: var(--gold-dim); }
        .report-info { display: flex; flex-direction: column; gap: 4px; }
        .report-name { font-size: 0.75rem; color: #fff; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 180px; }
        .download-link { background: var(--gold-dim); color: var(--gold); font-size: 0.6rem; text-decoration: none; padding: 6px 12px; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.05em; transition: 0.2s; }
        .download-link:hover { background: var(--gold); color: #000; }
        .detail-panel { display: none; background: var(--bg3); border-bottom: 1px solid var(--border); }
        .detail-panel.open { display: block; animation: slideDown 0.3s ease; }
        .chart-container { height: 180px; }
        .expand-btn { background: transparent; border: 1px solid var(--border); color: var(--gold); font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; padding: 6px 14px; border-radius: 4px; cursor: pointer; float: right; }
        footer { margin-top: 48px; padding-top: 20px; border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
        .footer-text { font-size: 0.6rem; color: var(--text-muted); text-transform: uppercase; }
    </style>
</head>
<body>

<div class="wrapper">
    <header>
        <div>
            <div class="logo">CRYPTO<span>TRACKER</span></div>
            <div style="font-size:0.62rem; color:var(--text-muted); margin-top:4px;">COMPUTAÇÃO EM NUVEM — IPCB</div>
        </div>
        <div class="header-meta">
            <div class="live-badge"><span class="live-dot"></span> Live</div>
            <div class="clock" id="clock">--:--:--</div>
        </div>
    </header>

    <table class="crypto-table">
        <thead>
            <tr><th>Moeda</th><th>Preço (EUR)</th><th style="text-align:center">Tendência</th><th style="text-align:right">Detalhe</th></tr>
        </thead>
        <tbody>
            <% if (coinData) { %>
                <% Object.keys(coinData).forEach((coin, i) => {
                    const cur = coinData[coin][coinData[coin].length - 1]?.price || 0;
                %>
                <tr class="coin-row" id="row-<%= coin %>" onclick="toggleDetail('<%= coin %>')" style="animation-delay: <%= i * 0.07 %>s">
                    <td><div class="coin-name"><%= coin %></div><div class="coin-sub">CoinGecko · EUR</div></td>
                    <td><span class="price-val" id="price-<%= coin %>" data-raw="<%= cur %>"><%= cur.toLocaleString('pt-PT', {minimumFractionDigits:2}) %>€</span></td>
                    <td class="trend-cell"><span class="trend-arrow trend-flat" id="trend-<%= coin %>">—</span></td>
                    <td><button class="expand-btn" id="btn-<%= coin %>">+ VER</button></td>
                </tr>
                <tr class="detail-row" id="detail-row-<%= coin %>"><td colspan="4">
                    <div class="detail-panel" id="detail-<%= coin %>">
                        <div style="padding:28px;"><div class="chart-container"><canvas id="chart-<%= coin %>"></canvas></div></div>
                    </div>
                </td></tr>
                <% }); %>
            <% } %>
        </tbody>
    </table>

    <div class="reports-dashboard">
        <div class="dashboard-title">📂 Histórico de Relatórios Gerados</div>
        <ul class="report-list" id="listaRelatorios">
            <% if (typeof reports !== 'undefined' && reports.length > 0) { %>
                <% reports.forEach(function(report) { %>
                    <li class="report-item">
                        <div class="report-info"><span class="report-name"><%= report %></span><span style="font-size:0.6rem; color:var(--text-muted);">Azure Storage</span></div>
                        <a href="/api/download/<%= report %>" class="download-link" target="_blank">Download</a>
                    </li>
                <% }); %>
            <% } else { %>
                <li style="font-size:0.7rem; color:var(--text-muted);">Ainda não existem relatórios.</li>
            <% } %>
        </ul>
    </div>

    <footer>
        <span class="footer-text">CryptoTracker © 2026 — João Oliveira · Tiago Pinheiro · Tiago Covas</span>
        <div style="display: flex; align-items: center; gap: 15px;">
            <button class="expand-btn" onclick="requestReport(this)" style="float:none; background:var(--gold-dim);">📊 GERAR RELATÓRIO PDF</button>
        </div>
    </footer>
</div>

<script>
    const socket = io();
    const charts = {};
    const coinHistories = <%- JSON.stringify(coinData) %>;

    function updateClock() { document.getElementById('clock').textContent = new Date().toLocaleTimeString('pt-PT'); }
    setInterval(updateClock, 1000); updateClock();

    function toggleDetail(coin) {
        const panel = document.getElementById(`detail-${coin}`);
        const isOpen = panel.classList.contains('open');
        document.querySelectorAll('.detail-panel').forEach(p => p.classList.remove('open'));
        if (!isOpen) {
            panel.classList.add('open');
            if (!charts[coin]) initChart(coin);
        }
    }

    function initChart(coin) {
        const ctx = document.getElementById(`chart-${coin}`).getContext('2d');
        const data = coinHistories[coin];
        charts[coin] = new Chart(ctx, {
            type: 'line',
            data: {
                labels: data.map(d => new Date(d.timestamp).toLocaleTimeString()),
                datasets: [{ data: data.map(d => d.price), borderColor: '#f0b90b', tension: 0.4 }]
            },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
        });
    }

    async function requestReport(btn) {
        btn.disabled = true; btn.textContent = '⌛ A GERAR...';
        try {
            const res = await fetch('/api/generate-report', { method: 'POST' });
            const data = await res.json();
            if (data.success) {
                const lista = document.getElementById('listaRelatorios');
                const li = document.createElement('li');
                li.className = 'report-item';
                li.innerHTML = `<div class="report-info"><span class="report-name">${data.filename}</span></div><a href="/api/download/${data.filename}" class="download-link" target="_blank">Download</a>`;
                lista.prepend(li);
                alert("Relatório guardado no Azure!");
            }
        } catch (err) { alert("Erro na geração."); }
        finally { btn.disabled = false; btn.textContent = '📊 GERAR RELATÓRIO PDF'; }
    }

    socket.on('priceUpdate', (newPrices) => {
        Object.keys(newPrices).forEach(coin => {
            const el = document.getElementById(`price-${coin}`);
            if (el) el.textContent = newPrices[coin].toLocaleString('pt-PT', {minimumFractionDigits:2}) + '€';
        });
    });
</script>
</body>
</html>